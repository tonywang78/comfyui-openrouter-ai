# =============================================================================
# Conni-X-Pro 根目录 .gitignore
# =============================================================================

# --- Maven / Java 构建产物 ---
target/
*.class
*.jar
*.war
*.ear
hs_err_pid*
replay_pid*

# --- 环境变量（含密钥，勿提交）---
.env
.env.local
.env.*.local
!.env.example

# --- IDE ---
.idea/
*.iml
*.ipr
*.iws
.vscode/*
!.vscode/extensions.json

# --- 日志 ---
logs/
*.log

# --- 操作系统 ---
.DS_Store
Thumbs.db
desktop.ini
