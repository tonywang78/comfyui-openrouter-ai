# =============================================================================
# Conni-X-Pro Docker Compose 环境变量
# 复制为 .env 后按需修改：cp .env.example .env
# =============================================================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=root_password_change_me
MYSQL_DATABASE=ghosts
DB_USERNAME=conni
DB_PASSWORD=conni_password_change_me

# --- Redis ---
REDIS_PASSWORD=redis_password_change_me

# --- 后端 Spring Boot（覆盖 application-*.yml 中的 127.0.0.1）---
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=9000

# --- 管理员初始化（首次启动）---
ADMIN_INIT_EMAIL=admin@example.com
ADMIN_INIT_PASSWORD=admin123

# --- 邮件（可选，不配置则验证码邮件不可用）---
MAIL_USERNAME=
MAIL_PASSWORD=

# --- 阿里云 OSS（文件上传必需）---
ALI_ACCESS_KEY=
ALI_SECRET_KEY=
ALI_OSS_BUCKET=
ALI_OSS_DOMAIN=https://your-bucket.oss-cn-beijing.aliyuncs.com
ALI_OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
ALI_OSS_SIGNED_URL_EXPIRE_SECONDS=3600

# --- OpenRouter（AI 对话必需）---
OPENROUTER_API_KEY=

# --- ComfyUI（工作流可选）---
COMFYUI_URL=http://192.168.2.86:8188

# --- 前端构建（经 Nginx 反代时保持默认即可）---
VITE_API_BASE_URL=/api
